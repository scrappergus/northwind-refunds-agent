#!/usr/bin/env bash
# Tail one of the project's log streams. Pops an fzf picker; pass a
# name to skip it:
#
#   bin/logs             # interactive
#   bin/logs dev         # local dev container (follows)
#   bin/logs do-run      # deployed app runtime (follows)
#   bin/logs do-build    # latest deployment's build logs
#   bin/logs do-deploy   # latest deployment's deploy logs
#
# The DigitalOcean entries need doctl plus the app id and context,
# which are read from the gitignored notes/deploy-digitalocean.md.
# Override with DO_APP_ID / DOCTL_CONTEXT if the notes move.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO="$(dirname "$SCRIPT_DIR")"
NOTES="$REPO/notes/deploy-digitalocean.md"

COLOR=1
[[ -t 1 ]] || COLOR=0
[[ -n "${NO_COLOR:-}" ]] && COLOR=0
[[ -n "${FORCE_COLOR:-}" ]] && COLOR=1
dim() { if (( COLOR )); then printf '\033[2m%s\033[0m' "$1"; else printf '%s' "$1"; fi; }

do_app_id() {
  if [[ -n "${DO_APP_ID:-}" ]]; then
    echo "$DO_APP_ID"
  elif [[ -f "$NOTES" ]]; then
    grep -oE '\(id [0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}\)' "$NOTES" \
      | head -1 | grep -oE '[0-9a-f-]{36}'
  fi
}

doctl_context() {
  if [[ -n "${DOCTL_CONTEXT:-}" ]]; then
    echo "$DOCTL_CONTEXT"
  elif [[ -f "$NOTES" ]]; then
    grep -oE '\*\*[a-z0-9-]+\*\* doctl context' "$NOTES" \
      | head -1 | sed 's/\*\*\([a-z0-9-]*\)\*\*.*/\1/'
  fi
}

do_logs() {
  command -v doctl >/dev/null || {
    echo "doctl required for deployed logs (brew install doctl)" >&2
    exit 1
  }
  APP_ID="$(do_app_id)"
  [[ -n "$APP_ID" ]] || {
    echo "no app id found — set DO_APP_ID or check $NOTES" >&2
    exit 1
  }
  CONTEXT="$(doctl_context)"
  exec doctl ${CONTEXT:+--context "$CONTEXT"} apps logs "$APP_ID" "$@"
}

desc_for() {
  case "$1" in
    dev)       echo "local dev container — docker compose (follows)" ;;
    do-run)    echo "deployed runtime — doctl apps logs (follows)" ;;
    do-build)  echo "latest deployment's build logs" ;;
    do-deploy) echo "latest deployment's deploy logs" ;;
  esac
}

CHOICE="${1:-}"
if [[ -z "$CHOICE" ]]; then
  command -v fzf >/dev/null || {
    echo "fzf required for the picker (brew install fzf)" >&2
    echo "or pass a name directly: bin/logs <dev|do-run|do-build|do-deploy>" >&2
    exit 1
  }

  LIST="$(
    for name in dev do-run do-build do-deploy; do
      printf '%-10s %s\n' "$name" "$(dim "$(desc_for "$name")")"
    done
  )"
  PICK="$(printf '%s\n' "$LIST" | fzf --ansi --prompt="tail which? " --height=40% \
            --color=fg+:black,bg+:yellow,hl+:black:bold,pointer:red:bold)" || exit 130
  [[ -z "$PICK" ]] && exit 0
  CHOICE="$(awk '{print $1}' <<<"$PICK")"
fi

case "$CHOICE" in
  dev)       exec docker compose -f "$REPO/docker-compose.dev.yml" logs -f dev ;;
  do-run)    do_logs --type run --follow ;;
  do-build)  do_logs --type build ;;
  do-deploy) do_logs --type deploy ;;
  *)
    echo "unknown log stream: $CHOICE" >&2
    echo "valid: dev do-run do-build do-deploy" >&2
    exit 1
    ;;
esac
