# Copy to .env.local and fill in. Read by docker-compose.dev.yml (env_file)
# and by Next.js directly when running outside Docker.
ANTHROPIC_API_KEY=sk-ant-...

# Optional hardening for public deployments (all off/default locally):
# DEMO_ADMIN_TOKEN=            # set to gate /admin, /api/logs, the ledger, and /api/chaos
# CHAT_RATE_LIMIT=20           # chat turns allowed per IP per window
# CHAT_RATE_WINDOW_SEC=300     # window length in seconds
# CF_ACCESS_TEAM_DOMAIN=       # e.g. yourteam.cloudflareaccess.com — with CF_ACCESS_AUD,
# CF_ACCESS_AUD=               # every API call must carry a valid Cf-Access-Jwt-Assertion
#                              # (seals direct-origin bypass of a Cloudflare Access gate)
